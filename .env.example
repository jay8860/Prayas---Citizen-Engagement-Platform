PORT=3000

# ── Admin security (MUST change before going live) ──────────────────────────
PRAYAS_ADMIN_PASSWORD=YourStrongPasswordHere
PRAYAS_TOKEN_SECRET=replace-with-a-256-bit-random-string

# ── CORS (set to your actual domain in production) ───────────────────────────
PRAYAS_ALLOWED_ORIGIN=https://your-domain.railway.app

# ── District identity (shown in certificates and portal branding) ─────────────
PRAYAS_DISTRICT_NAME=Raipur
PRAYAS_STATE_NAME=Chhattisgarh
PRAYAS_STATE_ABBR=CG
