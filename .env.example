PORT=3000

# ── Admin security (MUST change before going live) ──────────────────────────
PRAYAS_ADMIN_PASSWORD=YourStrongPasswordHere
PRAYAS_TOKEN_SECRET=replace-with-a-256-bit-random-string

# ── CORS (set to your actual domain in production) ───────────────────────────
PRAYAS_ALLOWED_ORIGIN=https://your-domain.railway.app

# ── District identity (shown in certificates, emails, and portal branding) ───
PRAYAS_DISTRICT_NAME=Raipur
PRAYAS_STATE_NAME=Chhattisgarh
PRAYAS_STATE_ABBR=CG

# ── Email via Gmail SMTP ─────────────────────────────────────────────────────
# 1. Enable 2FA on your Gmail: myaccount.google.com → Security → 2-Step Verification
# 2. Generate App Password: myaccount.google.com → Security → App Passwords
#    Select "Mail" and copy the 16-character password (remove spaces)
# 3. Set both variables below — leave empty to disable email features
PRAYAS_GMAIL_USER=prayas.district@gmail.com
PRAYAS_GMAIL_APP_PASSWORD=abcdefghijklmnop
PRAYAS_ADMIN_EMAIL=prayas.district@gmail.com
